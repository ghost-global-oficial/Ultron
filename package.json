{
  "name": "openclaw",
  "version": "1.0.0",
  "description": "Ultron - Moltbot Powered AI Assistant for Windows",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "build": "tsc -p tsconfig.json --noEmit false || true && node --import tsx scripts/copy-hook-metadata.ts && node --import tsx scripts/write-build-info.ts",
    "package": "electron-builder"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.13.1",
    "@aws-sdk/client-bedrock": "^3.980.0",
    "@buape/carbon": "0.14.0",
    "@clack/prompts": "^1.0.0",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@homebridge/ciao": "^1.3.4",
    "@line/bot-sdk": "^10.6.0",
    "@lydell/node-pty": "1.2.0-beta.3",
    "@mariozechner/pi-agent-core": "0.51.0",
    "@mariozechner/pi-ai": "0.51.0",
    "@mariozechner/pi-coding-agent": "0.51.0",
    "@mariozechner/pi-tui": "0.51.0",
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "0.34.48",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.13.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "ajv": "^8.17.1",
    "bonjour-service": "^1.3.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "discord-api-types": "^0.38.38",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "file-type": "^21.3.0",
    "grammy": "^1.39.3",
    "hono": "4.11.7",
    "hyperswarm": "^4.17.0",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "long": "^5.3.2",
    "markdown-it": "^14.1.0",
    "node-edge-tts": "^1.2.9",
    "osc-progress": "^0.3.0",
    "pdfjs-dist": "^5.4.624",
    "playwright-core": "1.58.1",
    "proper-lockfile": "^4.1.2",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "signal-utils": "^0.21.1",
    "sqlite-vec": "0.1.7-alpha.2",
    "tar": "7.5.7",
    "tslog": "^4.10.2",
    "undici": "^7.20.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@grammyjs/types": "^3.23.0",
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.2.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  },
  "build": {
    "appId": "com.ultron.app",
    "productName": "Ultron",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ultron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "index.html",
      "renderer.js",
      "package.json"
    ]
  }
}
